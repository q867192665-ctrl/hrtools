<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/menu_header_bg"
            android:padding="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="欢迎，用户"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="请假管理"
                android:textSize="14sp"
                android:textColor="#E0E0E0"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="请假申请"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="请假类型"
                                android:textSize="13sp"
                                android:textColor="#757575" />

                            <Spinner
                                android:id="@+id/spinnerLeaveType"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="2"
                                android:background="@drawable/spinner_bg"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="开始日期"
                                android:textSize="13sp"
                                android:textColor="#757575" />

                            <EditText
                                android:id="@+id/etStartDate"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="2"
                                android:hint="点击选择日期"
                                android:focusable="false"
                                android:clickable="true"
                                android:textSize="13sp"
                                android:textColor="#1A1A1A"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:background="@drawable/spinner_bg" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="结束日期"
                                android:textSize="13sp"
                                android:textColor="#757575" />

                            <EditText
                                android:id="@+id/etEndDate"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="2"
                                android:hint="点击选择日期"
                                android:focusable="false"
                                android:clickable="true"
                                android:textSize="13sp"
                                android:textColor="#1A1A1A"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:background="@drawable/spinner_bg" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="请假天数"
                                android:textSize="13sp"
                                android:textColor="#757575" />

                            <EditText
                                android:id="@+id/etLeaveDays"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="2"
                                android:hint="自动计算"
                                android:inputType="numberDecimal"
                                android:textSize="13sp"
                                android:textColor="#1A1A1A"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:background="@drawable/spinner_bg" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="请假原因"
                                android:textSize="13sp"
                                android:textColor="#757575"
                                android:layout_marginBottom="8dp" />

                            <EditText
                                android:id="@+id/etReason"
                                android:layout_width="match_parent"
                                android:layout_height="100dp"
                                android:hint="请输入请假原因（可选）"
                                android:gravity="top"
                                android:textSize="13sp"
                                android:textColor="#1A1A1A"
                                android:padding="12dp"
                                android:background="@drawable/spinner_bg" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="提交申请"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"
                    app:backgroundTint="#4CAF50"
                    app:rippleColor="#388E3C"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewRecords"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="查看记录"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"
                    app:strokeColor="#BBDEFB"
                    app:strokeWidth="1dp"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#2196F3"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackToMenu"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="返回菜单"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="退出登录"
                    android:textSize="15sp"
                    app:cornerRadius="10dp"
                    app:strokeColor="#FFCDD2"
                    app:strokeWidth="1dp"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="#F44336"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</RelativeLayout>
