<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.IPv6Communicator" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:editTextColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
    </style>
    
    <style name="SpinnerStyle" parent="Widget.AppCompat.Spinner">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:background">@drawable/spinner_bg</item>
    </style>
    
    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="android:background">@drawable/edittext_bg</item>
    </style>
</resources>
